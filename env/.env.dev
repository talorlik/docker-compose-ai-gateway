BENCH_EXPERIMENT_ID=baseline
BENCH_MAX_RETRIES=3
BENCH_METRICS_INTERVAL_SEC=5
BENCH_PROFILE=mac_performance
COMPOSE_WORKING_DIR=/workspace
DEMO_RUN_AUGMENT=true
DEMO_RUN_RELABEL=true
DEMO_START_BACKEND=true
LOG_LEVEL=debug
MODEL_ARTIFACTS_PATH=/model
OLLAMA_BACKEND_ENFORCE_EXCLUSIVE=true
OLLAMA_CONTAINER_SERVICE=ollama
OLLAMA_FLASH_ATTENTION=0
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_KEEP_ALIVE=30m
OLLAMA_KV_CACHE_TYPE=f16
OLLAMA_MAX_INFLIGHT_PER_INSTANCE=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=512
OLLAMA_MODE=native
OLLAMA_MODEL=phi3:mini
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PARALLEL=1
OLLAMA_NUM_PREDICT=120
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_URLS=http://host.docker.internal:11434
PROMOTE_TARGET_PATH=/promote_target
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
REDIS_URL=redis://redis:6379/0
REFINER_AUGMENT_MAX_PARALLEL_LABELS=1
REFINER_AUGMENT_MAX_RETRIES=3
REFINER_AUGMENT_NUM_CTX=768
REFINER_AUGMENT_NUM_PREDICT=180
REFINER_AUGMENT_N_PER_LABEL=3
REFINER_AUGMENT_VERIFY_LABELS=true
REFINER_AUGMENT_VERIFY_MIN_CONFIDENCE=0.8
REFINER_AUGMENT_MAX_TEXT_LENGTH=100
REFINER_AUGMENT_SEED_EXAMPLES=3
REFINER_PROMOTE_ACCURACY_TOLERANCE=0.01
REFINER_LIMIT=5
REFINER_RELABEL_BATCH_SIZE=25
REFINER_RELABEL_MAX_PARALLEL_BATCHES=1
REFINER_RELABEL_MAX_RETRIES=3
REFINER_RELABEL_NUM_CTX=1024
REFINER_RELABEL_NUM_PREDICT=120
REFINER_SEED=42
REFINER_STRUCTURED_OUTPUT_ENABLED=true
REFINER_TEMPERATURE=0.1
REQUEST_TIMEOUT=30
